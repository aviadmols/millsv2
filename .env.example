APP_NAME="Mills Subscriptions"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=he
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=he_IL

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────
# Mills v2 env contract (ARCHITECTURE.md §8)
# ─────────────────────────────────────────────────────────────

# Frozen API contract (theme calls these)
API_SECRET=
STOREFRONT_TOKEN_SECRET=
STOREFRONT_TOKEN_MAX_AGE_SECONDS=86400

# Shopify app (Partner Dashboard, custom distribution). The offline access token
# is captured via OAuth and stored ENCRYPTED in the DB — not here.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2026-07
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,write_orders,read_draft_orders,write_draft_orders,read_customers,write_customers
SHOPIFY_SALES_CHANNEL_HANDLE=mills-subscriptions
SHOPIFY_ORDER_SOURCE_NAME=mills-subscriptions
SHOPIFY_SUBSCRIPTION_PRODUCT_ID=8499033800792

# PayMe
PAYME_API_URL=
PAYME_SELLER_ID=
PAYME_HOSTED_FIELDS_API_KEY=
PAYME_HOSTED_FIELDS_TEST_MODE=false

# Billing (the ONLY off switch is the kill switch — no cache toggle)
BILLING_KILL_SWITCH=false
BILLING_DISPATCH_WINDOW_MINUTES=0

# SMS via 019 (adapter built when credentials arrive)
SMS_CHANNEL=019
SMS_019_BASE_URL=https://019sms.co.il/api
SMS_019_USERNAME=
SMS_019_TOKEN=
SMS_019_SENDER=Mills

# Production drivers on Railway (override the sqlite/database defaults above):
#   DB_CONNECTION=pgsql   QUEUE_CONNECTION=redis   CACHE_STORE=redis
# SMTP is admin-managed (mail_settings) — the MAIL_* vars are only the bootstrap default.
